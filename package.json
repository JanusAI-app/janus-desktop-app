{
  "name": "janus-desktop",
  "version": "1.0.0",
  "description": "Janus – Desktop-App (Mac, Windows, Linux)",
  "main": "main.js",
  "author": "Janus",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:linux": "electron-builder --linux --publish never"
  },
  "build": {
    "appId": "de.janus.app",
    "productName": "Janus",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "build/**",
      "node_modules/**/*"
    ],
    "afterPack": "./afterPack.js",
    "dmg": {
      "artifactName": "Janus.dmg"
    },
    "nsis": {
      "artifactName": "Janus-Setup.exe"
    },
    "appImage": {
      "artifactName": "Janus.AppImage"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "identity": null,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Janus nutzt dein Mikrofon für den Sprachmodus (mit Janus sprechen)."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6"
  }
}
